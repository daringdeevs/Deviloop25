    m_Metadata:
      m_Items: []
  - m_Id: 7568845746195
    m_Localized: 'Narrator: You make your way into a new town...'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746196
    m_Localized: 'Narrator: Where are you heading?'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746197
    m_Localized: Caves!
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746198
    m_Localized: Ruined castle!
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746199
    m_Localized: Leave town.
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746200
    m_Localized: 'Narrator: You make your way into the forboding caves.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746201
    m_Localized: 'Narrator: The blackness of the caves beckons...'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746202
    m_Localized: 'Narrator: Go deeper?'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746203
    m_Localized: Yes.
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746204
    m_Localized: 'Narrator: You push deeper into the black.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746205
    m_Localized: 'Narrator: You find a pile of gold!'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746206
    m_Localized: 'Narrator: You return to town with your riches.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746207
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746208
    m_Localized: 'Narrator: The caves are scary.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746209
    m_Localized: 'Narrator: Back to town!'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746210
    m_Localized: 'Narrator: You wander into the ruined castle...'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746211
    m_Localized: 'Narrator: With your gold, you''d best keep your wits about you.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746212
    m_Localized: 'Narrator: Unfortunately, there''s nothing of interest here...'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746213
    m_Localized: 'Narrator: You head back to town!'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746214
    m_Localized: 'Narrator: You wander off, in search of your next adventure.'
    m_Metadata:
      m_Items: []
  - m_Id: 10247202451456
    m_Localized: 'Vendor: Do you want to buy a weapon?'
    m_Metadata:
      m_Items: []
  - m_Id: 10247202451457
    m_Localized: Yes! I'll take the Sword.
    m_Metadata:
      m_Items: []
  - m_Id: 10247202451458
    m_Localized: 'Vendor: OK! Here''s your sword.'
    m_Metadata:
      m_Items: []

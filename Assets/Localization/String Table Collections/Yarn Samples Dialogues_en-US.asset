  m_TableData:
  - m_Id: 41999446016
    m_Localized: Once upon a time...
    m_Metadata:
      m_Items: []
  - m_Id: 42028806144
    m_Localized: 'Player: Oh, [wave]hello[/wave] there {0}!'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806145
    m_Localized: 'NPC: Oh, hello! How can I help you today?'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806146
    m_Localized: Show me the "Detour" example.
    m_Metadata:
      m_Items: []
  - m_Id: 42028806147
    m_Localized: 'NPC: What would you like to know?'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806148
    m_Localized: Show me the "Flow Control" example.
    m_Metadata:
      m_Items: []
  - m_Id: 42028806149
    m_Localized: 'NPC: Jumping to the "flow control" example!!'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806150
    m_Localized: Actually, I should go.
    m_Metadata:
      m_Items: []
  - m_Id: 42028806151
    m_Localized: 'NPC: No problem. Come back anytime! We have even more examples
      to check!'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806152
    m_Localized: 'Player: Thanks for your help!'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806153
    m_Localized: 'NPC: You''re welcome! Have a nice day!'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806154
    m_Localized: 'TODO: Add more dialogue options for the NPC.'
    m_Metadata:
      m_Items: []
  - m_Id: 42028806155
    m_Localized: 'Guard: Have I told you my backstory?'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000448
    m_Localized: Yes.
    m_Metadata:
      m_Items: []
  - m_Id: 42033000449
    m_Localized: 'Guard: Oh. Well, then.'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000450
    m_Localized: No?
    m_Metadata:
      m_Items: []
  - m_Id: 42033000451
    m_Localized: 'Guard: Anyway, you can''t come in.'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000452
    m_Localized: 'Guard: Do you want the detailed version or the short version?'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000453
    m_Localized: Detailed.
    m_Metadata:
      m_Items: []
  - m_Id: 42033000454
    m_Localized: 'Guard: I hope you enjoyed learning all that.. Anyway...'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000455
    m_Localized: Short.
    m_Metadata:
      m_Items: []
  - m_Id: 42033000456
    m_Localized: 'Guard: Right, well, I was a recruit, then I wasn''t.'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000457
    m_Localized: 'Guard: It all started when I was a mere recruit.'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000458
    m_Localized: 'Guard: Want to hear more?'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000459
    m_Localized: Yes.
    m_Metadata:
      m_Items: []
  - m_Id: 42033000460
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 42033000461
    m_Localized: 'Guard: (speaks more garbage)'
    m_Metadata:
      m_Items: []
  - m_Id: 42033000462
    m_Localized: The value of variableName is {0}.
    m_Metadata:
      m_Items: []
  - m_Id: 1473309880320
    m_Localized: 'Player: I''d like to buy a pie!'
    m_Metadata:
      m_Items: []
  - m_Id: 1473309880321
    m_Localized: 'Baker: Well, you can''t afford one!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306880
    m_Localized: 'Player: I''d like to buy a pie!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306881
    m_Localized: 'Baker: Well, you can''t afford one!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306882
    m_Localized: 'Baker: You can almost afford one!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306883
    m_Localized: 'Baker: You can afford a pie!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306884
    m_Localized: 'Guard: You''re not allowed in!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306885
    m_Localized: Sure I am! The boss knows me!
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306886
    m_Localized: Please?
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306887
    m_Localized: I'll come back later.
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306888
    m_Localized: 'Guard: Who goes there?'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306889
    m_Localized: A thief!
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306890
    m_Localized: A merchant!
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306891
    m_Localized: 'Player: I''m nobody!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306892
    m_Localized: 'Guard: get the thief!'
    m_Metadata:
      m_Items: []
  - m_Id: 5195293306893
    m_Localized: 'Guard: what are you selling?'
    m_Metadata:
      m_Items: []
  - m_Id: 24304735268960
    m_Localized: Now we won't arrive in time at the next stop!
    m_Metadata:
      m_Items: []
  - m_Id: 24304735268959
    m_Localized: Why did you stop the train?
    m_Metadata:
      m_Items: []
  - m_Id: 24304735268958
    m_Localized: 'Homer: Hi, I''d like to order a tire balancing.'
    m_Metadata:
      m_Items: []
  - m_Id: 24304735268957
    m_Localized: 'Innkeeper: Most shops are closed now, but you''re welcome to stay
      here for the night.'
    m_Metadata:
      m_Items: []
  - m_Id: 24304735268956
    m_Localized: 'Craftsman: Your carpentry skills aren''t quite there yet.'
    m_Metadata:
      m_Items: []
  - m_Id: 7568845746181
